mns\\.Add\\(\\$col\\)\n            \\}\n          \\}\n        \\}\n      \\}\n    \\}\n\n    \\$englishValues = @\\(Get-NonEmptyValues \\$row @\\('Fully specified name:en','Short name:en'\\) \\| Select-Object -Unique\\)\n    \\$englishJoined = \\(\\$englishValues -join ' \\| '\\)\n\n    foreach \\(\\$entry in \\$esMap\\.GetEnumerator\\(\\)\\) \\{\n      \\$occurrences\\.Add\\(\\[pscustomobject\\]@\\{\n        EsValue = \\$entry\\.Value\\.Value\n        Uuid = \\$uuid\n        English = \\$englishJoined\n        File = \\$file\\.Name\n        Columns = \\(\\$entry\\.Value\\.Columns -join ', '\\)\n      \\}\\) \\| Out-Null\n    \\}\n  \\}\n\\}\n\n\\$collisions = \\$occurrences \\|\n  Group-Object EsValue \\|\n  Where-Object \\{ \\(@\\(\\$_\\.Group \\| Select-Object -ExpandProperty Uuid -Unique\\)\\)\\.Count -gt 1 \\} \\|\n  Sort-Object Name\n\nWrite-Output '=== COLISIONES REALES DE NOMBRES EN ESPANOL \\(UUID distintos\\) ==='\nif \\(\\$collisions\\.Count -eq 0\\) \\{\n  Write-Output 'SIN COLISIONES'\n\\}\nelse \\{\n  \\$table = foreach \\(\\$g in \\$collisions\\) \\{\n    \\$distinctUuids = @\\(\\$g\\.Group \\| Select-Object -ExpandProperty Uuid -Unique\\)\n    \\$engByUuid = @\\(\\)\n    foreach \\(\\$u in \\$distinctUuids\\) \\{\n      \\$eng = @\\(\\$g\\.Group \\| Where-Object \\{ \\$_\\.Uuid -eq \\$u \\} \\| Select-Object -ExpandProperty English -Unique \\| Where-Object \\{ -not \\[string\\]::IsNullOrWhiteSpace\\(\\$_\\) \\}\\)\n      if \\(\\$eng\\.Count -eq 0\\) \\{ \\$eng = @\\('\\(sin nombre ingles\\)'\\) \\}\n      \\$engByUuid \\+= \\(\\$u \\+ ': ' \\+ \\(\\$eng -join ' \\|\\| '\\)\\)\n    \\}\n    \\$fileList = @\\(\\$g\\.Group \\| Select-Object -ExpandProperty File -Unique\\)\n    \\[pscustomobject\\]@\\{\n      'Valor es' = \\$g\\.Name\n      'UUID distintos' = \\$distinctUuids\\.Count\n      UUIDs = \\(\\$distinctUuids -join '; '\\)\n      'Nombres ingleses' = \\(\\$engByUuid -join ' ; '\\)\n      Archivos = \\(\\$fileList -join '; '\\)\n    \\}\n  \\}\